FROM python:3.12-slim AS builder
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/
ENV UV_COMPILE_BYTECODE=1 UV_LINK_MODE=copy
WORKDIR /app
RUN --mount=type=cache,target=/root/.cache/uv \
    --mount=type=bind,source=uv.lock,target=uv.lock \
    --mount=type=bind,source=pyproject.toml,target=pyproject.toml \
    --mount=type=bind,source=packages/centinela-core/pyproject.toml,target=packages/centinela-core/pyproject.toml \
    --mount=type=bind,source=services/audit/pyproject.toml,target=services/audit/pyproject.toml \
    --mount=type=bind,source=services/blue-agent/pyproject.toml,target=services/blue-agent/pyproject.toml \
    --mount=type=bind,source=services/llm-sandbox/pyproject.toml,target=services/llm-sandbox/pyproject.toml \
    --mount=type=bind,source=services/orchestrator/pyproject.toml,target=services/orchestrator/pyproject.toml \
    --mount=type=bind,source=services/red-agent/pyproject.toml,target=services/red-agent/pyproject.toml \
    uv sync --locked --no-dev --no-editable --no-install-project
COPY . .
RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --locked --no-dev --no-editable

FROM python:3.12-slim
ENV PATH="/app/.venv/bin:$PATH"
COPY --from=builder --chown=nonroot:nonroot /app/.venv /app/.venv
COPY --from=builder --chown=nonroot:nonroot /app/services/llm-sandbox /app/services/llm-sandbox
WORKDIR /app/services/llm-sandbox
HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD python -c "from llm_sandbox import main; exit(0)"
USER nonroot
CMD ["python", "-m", "llm_sandbox"]
